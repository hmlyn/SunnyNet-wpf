<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>SunnyNet</AssemblyName>
    <AssemblyTitle>SunnyNet</AssemblyTitle>
    <Product>SunnyNet</Product>
    <Company>SunnyNet</Company>
    <Description>SunnyNet Windows 抓包分析工具</Description>
    <Version>0.1.5</Version>
    <AssemblyVersion>0.1.5.0</AssemblyVersion>
    <FileVersion>0.1.5.0</FileVersion>
    <InformationalVersion>0.1.5</InformationalVersion>
    <ApplicationIcon>Resources\AppIcon.ico</ApplicationIcon>
  </PropertyGroup>

  <PropertyGroup>
    <BackendDir>$(MSBuildThisFileDirectory)..\..\backend\</BackendDir>
    <ZigExe Condition="'$(ZigExe)' == '' and Exists('$(MSBuildThisFileDirectory)..\..\_toolchain\zig-x86_64-windows-0.15.2\zig.exe')">$(MSBuildThisFileDirectory)..\..\_toolchain\zig-x86_64-windows-0.15.2\zig.exe</ZigExe>
    <ZigExe Condition="'$(ZigExe)' == ''">zig</ZigExe>
    <McpBridgeSource>$(MSBuildThisFileDirectory)..\..\sunnymcptool\build\bin\sunnynet-mcp.exe</McpBridgeSource>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>

  <Target Name="BuildGoBackend" BeforeTargets="Build" Condition="'$(DesignTimeBuild)' != 'true'">
    <MakeDir Directories="$(TargetDir)backend" />
    <Exec Command="set CC=$(ZigExe) cc -target x86_64-windows-gnu &amp;&amp; set CXX=$(ZigExe) c++ -target x86_64-windows-gnu &amp;&amp; go build -tags cshared -buildmode=c-shared -o &quot;$(TargetDir)backend\SunnyNetBridge.dll&quot; ." WorkingDirectory="$(BackendDir)" />
  </Target>

  <Target Name="CopyMcpBridge" AfterTargets="Build" Condition="'$(DesignTimeBuild)' != 'true' and Exists('$(McpBridgeSource)')">
    <MakeDir Directories="$(TargetDir)mcp" />
    <Copy SourceFiles="$(McpBridgeSource)"
          DestinationFiles="$(TargetDir)mcp\sunnynet-mcp.exe"
          SkipUnchangedFiles="true" />
  </Target>

  <Target Name="RemoveLegacyOutputName" AfterTargets="Build" Condition="'$(DesignTimeBuild)' != 'true'">
    <ItemGroup>
      <LegacyOutput Include="$(TargetDir)SunnyNet.Wpf.*" />
    </ItemGroup>
    <Delete Files="@(LegacyOutput)" TreatErrorsAsWarnings="true" />
  </Target>

  <ItemGroup>
    <Resource Include="Resources\AppIcon.ico" />
    <Resource Include="Resources\AppIcon.png" />
    <Resource Include="Resources\SponsorWeChat.png" Condition="Exists('Resources\SponsorWeChat.png')" />
  </ItemGroup>

</Project>
