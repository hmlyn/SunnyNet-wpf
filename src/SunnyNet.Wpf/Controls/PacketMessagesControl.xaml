<UserControl x:Class="SunnyNet.Wpf.Controls.PacketMessagesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SunnyNet.Wpf.Controls"
             xmlns:models="clr-namespace:SunnyNet.Wpf.Models">
    <UserControl.Resources>
        <Style x:Key="PacketHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PacketCellTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="PacketMonoCellTextStyle" TargetType="TextBlock" BasedOn="{StaticResource PacketCellTextStyle}">
            <Setter Property="FontFamily" Value="Consolas, Microsoft YaHei UI" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="11.5" />
        </Style>

        <Style x:Key="PacketDirectionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource PacketCellTextStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Icon}" Value="上行">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Icon}" Value="下行">
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PacketItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="0">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F7FAFE" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EEF4FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border x:Name="FlowPanel"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="10,10,0,0">
                    <DockPanel Margin="12,0" LastChildFill="False">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="{Binding ProtocolName, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat={}{0} 包列表}" />
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Padding="8,3"
                                    Background="{StaticResource AccentSoftBrush}"
                                    BorderBrush="{StaticResource DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="7">
                                <TextBlock x:Name="TotalPacketsTextBlock"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold"
                                           Text="0 包" />
                            </Border>
                            <Border Margin="6,0,0,0"
                                    Padding="8,3"
                                    Background="#EAF8F1"
                                    BorderBrush="#CBE9D8"
                                    BorderThickness="1"
                                    CornerRadius="7">
                                <TextBlock x:Name="UpstreamPacketsTextBlock"
                                           Foreground="{StaticResource SuccessBrush}"
                                           Text="上行 0" />
                            </Border>
                            <Border Margin="6,0,0,0"
                                    Padding="8,3"
                                    Background="#EEF4FF"
                                    BorderBrush="#D8E7FF"
                                    BorderThickness="1"
                                    CornerRadius="7">
                                <TextBlock x:Name="DownstreamPacketsTextBlock"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="下行 0" />
                            </Border>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1"
                        Margin="8,4,8,0"
                        Padding="10,0"
                        Background="#F7FAFD"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="1,1,1,0"
                        CornerRadius="8,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="104" />
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="86" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource PacketHeaderTextStyle}" Text="#" />
                        <TextBlock Grid.Column="1" Style="{StaticResource PacketHeaderTextStyle}" Text="时间" />
                        <TextBlock Grid.Column="2" Style="{StaticResource PacketHeaderTextStyle}" Text="方向" />
                        <TextBlock Grid.Column="3" Style="{StaticResource PacketHeaderTextStyle}" Text="长度" />
                        <TextBlock Grid.Column="4" Style="{StaticResource PacketHeaderTextStyle}" Text="数据摘要" />
                    </Grid>
                </Border>

                <ListBox x:Name="PacketsList"
                         Grid.Row="2"
                         Margin="8,0,8,8"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource PacketItemStyle}"
                         PreviewMouseRightButtonDown="PacketsList_PreviewMouseRightButtonDown"
                         ScrollViewer.CanContentScroll="True"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.CacheLength="1,1"
                         VirtualizingPanel.CacheLengthUnit="Page"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         SelectionChanged="PacketsList_SelectionChanged">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ContextMenu>
                        <ContextMenu Opened="PacketContextMenu_Opened">
                            <MenuItem x:Name="CopyPacketSummaryMenuItem" Header="复制包摘要" Click="CopyPacketSummary_Click" />
                            <MenuItem x:Name="CopyPacketTextMenuItem" Header="复制包文本" Click="CopyPacketText_Click" />
                            <MenuItem x:Name="CopyPacketHexMenuItem" Header="复制包 HEX" Click="CopyPacketHex_Click" />
                            <MenuItem x:Name="CopyPacketBase64MenuItem" Header="复制包 Base64" Click="CopyPacketBase64_Click" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:SocketEntry}">
                            <Border BorderBrush="{Binding SearchBorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{Binding CardBackground}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter Property="Background" Value="#F7FAFE" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter Property="Background" Value="#EEF4FF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid Height="34" Margin="10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="104" />
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource PacketMonoCellTextStyle}" Text="{Binding CompactIndex}" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource PacketMonoCellTextStyle}" Text="{Binding TimeLabel}" />
                                    <TextBlock Grid.Column="2" Style="{StaticResource PacketDirectionTextStyle}" Text="{Binding DirectionLabel}" />
                                    <TextBlock Grid.Column="3" Style="{StaticResource PacketMonoCellTextStyle}" Text="{Binding LengthLabel}" />
                                    <TextBlock Grid.Column="4"
                                               Style="{StaticResource PacketCellTextStyle}"
                                               Text="{Binding PreviewTextShort}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border x:Name="PacketsEmptyPanel"
                        Grid.RowSpan="3"
                        Margin="8,40,8,8"
                        Background="#F8FAFD"
                        CornerRadius="10"
                        IsHitTestVisible="False">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="22"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="&#xE8AB;" />
                        <TextBlock x:Name="PacketsEmptyTitleTextBlock"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Text="暂无数据包" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="InspectorPanel"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="0" />
                    <RowDefinition Height="0" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="10,10,0,0"
                        Visibility="Collapsed">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="InspectorTitleTextBlock"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="请选择一个数据包"
                                   TextTrimming="CharacterEllipsis" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border x:Name="InspectorDirectionBadge"
                                    Padding="8,2"
                                    Background="#EEF4FF"
                                    BorderBrush="#D8E7FF"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <TextBlock x:Name="InspectorDirectionTextBlock"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold"
                                           Text="方向" />
                            </Border>
                            <Border Margin="6,0,0,0"
                                    Padding="8,2"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <TextBlock x:Name="InspectorLengthTextBlock"
                                           Style="{StaticResource CaptionTextStyle}"
                                           Text="0 B" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="10,6,10,6"
                        Padding="8,5"
                        Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed">
                    <TextBlock x:Name="InspectorHintTextBlock"
                               Style="{StaticResource CaptionTextStyle}"
                               Text="左侧选择数据包后，这里异步载入正文、JSON 和 HEX。"
                               TextTrimming="CharacterEllipsis" />
                </Border>

                <Grid Grid.Row="2"
                      Margin="6,0,6,6"
                      MinHeight="0">
                    <Grid x:Name="InspectorEmptyPanel">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="22"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="&#xE70F;" />
                            <TextBlock Margin="0,8,0,0"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       Text="选择数据包查看内容" />
                        </StackPanel>
                    </Grid>

                    <TabControl x:Name="PacketPayloadTabs"
                                Visibility="Collapsed">
                        <TabItem x:Name="PacketRawTab" Header="原文">
                            <controls:HttpSyntaxTextBox x:Name="PacketRawViewer"
                                                        HorizontalScrollBarVisibility="Disabled"
                                                        HighlightMode="Body" />
                        </TabItem>
                        <TabItem x:Name="PacketJsonTab" Header="JSON视图">
                            <controls:JsonTreeViewControl x:Name="PacketJsonViewer" />
                        </TabItem>
                        <TabItem Header="HEX视图">
                            <controls:HexViewControl x:Name="PacketHexViewer"
                                                     EmptyText="当前数据包无二进制内容" />
                        </TabItem>
                        <TabItem x:Name="PacketProtobufTab" Header="ProtoBuf">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Margin="0,0,0,6"
                                        Padding="0"
                                        Background="Transparent">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="4" />
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="58" />
                                                <ColumnDefinition Width="4" />
                                                <ColumnDefinition Width="42" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Text="结构" />
                                            <TextBox x:Name="PacketProtoSchemaPathTextBox"
                                                     Grid.Column="1"
                                                     MinHeight="26"
                                                     Padding="8,2"
                                                     ToolTip="支持选择一个或多个 .proto / .pb / .desc / .protoset 描述文件" />
                                            <Button Grid.Column="3"
                                                    MinHeight="26"
                                                    Padding="0"
                                                    Content="…"
                                                    ToolTip="选择并自动导入 Protobuf 描述文件"
                                                    Click="BrowsePacketProtoSchema_Click" />
                                            <Button Grid.Column="5"
                                                    MinHeight="26"
                                                    Padding="6,2"
                                                    Content="解析"
                                                    Click="ParsePacketProtobuf_Click" />
                                            <Button Grid.Column="7"
                                                    MinHeight="26"
                                                    Padding="6,2"
                                                    Content="清空"
                                                    Click="ClearPacketProtobuf_Click" />
                                        </Grid>

                                        <Grid Grid.Row="1" Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="4" />
                                                <ColumnDefinition Width="26" />
                                                <ColumnDefinition Width="4" />
                                                <ColumnDefinition Width="26" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Text="类型" />
                                            <ComboBox x:Name="PacketProtoMessageTypeComboBox"
                                                      Grid.Column="1"
                                                      MinHeight="26"
                                                      Padding="8,2"
                                                      IsEditable="True"
                                                      IsTextSearchEnabled="True"
                                                      ToolTip="选择 Protobuf 消息类型" />
                                            <TextBlock Grid.Column="3"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Text="头部" />
                                            <TextBox x:Name="PacketProtobufSkipTextBox"
                                                     Grid.Column="4"
                                                     MinHeight="26"
                                                     Padding="8,2"
                                                     Text="0"
                                                     ToolTip="忽略前 N 个自定义包头字节"
                                                     TextChanged="PacketProtobufSkipTextBox_TextChanged" />
                                            <Button Grid.Column="6"
                                                    MinHeight="26"
                                                    Padding="0"
                                                    Content="-"
                                                    Tag="-1"
                                                    Click="AdjustPacketProtobufSkip_Click" />
                                            <Button Grid.Column="8"
                                                    MinHeight="26"
                                                    Padding="0"
                                                    Content="+"
                                                    Tag="1"
                                                    Click="AdjustPacketProtobufSkip_Click" />
                                        </Grid>

                                        <TextBlock x:Name="PacketProtobufStatusTextBlock"
                                                   Grid.Row="2"
                                                   Margin="0,5,0,0"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="选择数据包后，可按结构解析当前载荷。"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="1" MinHeight="0">
                                    <controls:JsonTreeViewControl x:Name="PacketProtobufViewer" />
                                    <Border x:Name="PacketProtobufEmptyPanel"
                                            Background="#F8FAFD"
                                            IsHitTestVisible="False">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock HorizontalAlignment="Center"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="22"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="&#xE943;" />
                                            <TextBlock x:Name="PacketProtobufEmptyTextBlock"
                                                       Margin="0,8,0,0"
                                                       HorizontalAlignment="Center"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Text="设置结构、类型和头部字节后解析" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>
                        <TabItem x:Name="PacketReplayTab" Header="主动发送">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="126" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="108" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="78" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="方向" />
                                    <ComboBox x:Name="PacketReplayDirectionComboBox"
                                              Grid.Column="1"
                                              MinHeight="26"
                                              Padding="8,2">
                                        <ComboBoxItem Content="发送到服务端" Tag="Server" />
                                        <ComboBoxItem Content="发送到客户端" Tag="Client" />
                                    </ComboBox>
                                    <TextBlock Grid.Column="3"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="格式" />
                                    <ComboBox x:Name="PacketReplayEncodingComboBox"
                                              Grid.Column="4"
                                              MinHeight="26"
                                              Padding="8,2"
                                              SelectionChanged="PacketReplayEncodingComboBox_SelectionChanged">
                                        <ComboBoxItem Content="HEX" Tag="HEX" />
                                        <ComboBoxItem Content="文本" Tag="UTF8" />
                                        <ComboBoxItem Content="Base64" Tag="Base64" />
                                    </ComboBox>
                                    <Button Grid.Column="6"
                                            MinHeight="26"
                                            Padding="10,2"
                                            Content="发送"
                                            Click="SendPacketReplay_Click" />
                                </Grid>

                                <Grid Grid.Row="1" MinHeight="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBox x:Name="PacketReplayEditorTextBox"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             FontFamily="Consolas, Microsoft YaHei UI"
                                             FontSize="12"
                                             HorizontalScrollBarVisibility="Disabled"
                                             TextChanged="PacketReplayEditorTextBox_TextChanged"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" />
                                    <TextBlock x:Name="PacketReplayStatusTextBlock"
                                               Grid.Row="1"
                                               Margin="0,5,0,0"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="选择数据包后会自动回填当前载荷，可修改后发送。"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
