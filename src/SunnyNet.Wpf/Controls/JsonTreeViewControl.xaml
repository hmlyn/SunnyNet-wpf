<UserControl x:Class="SunnyNet.Wpf.Controls.JsonTreeViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SunnyNet.Wpf.Controls">
    <UserControl.Resources>
        <Style x:Key="JsonTreeExpanderStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ExpanderBorder"
                                Background="Transparent"
                                CornerRadius="4">
                            <Path x:Name="Arrow"
                                  Width="5"
                                  Height="9"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Data="M 0 0 L 4 4.5 L 0 9"
                                  SnapsToDevicePixels="True"
                                  Stroke="#8EA1B6"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeThickness="1.6">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="0" CenterX="2.5" CenterY="4.5" />
                                </Path.RenderTransform>
                            </Path>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ExpanderBorder" Property="Background" Value="#EEF4FB" />
                                <Setter TargetName="Arrow" Property="Stroke" Value="#6C88AE" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90" CenterX="2.5" CenterY="4.5" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Arrow" Property="Stroke" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="JsonTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ToggleButton x:Name="Expander"
                                          Grid.Row="0"
                                          Grid.Column="0"
                                          Margin="0,5,4,0"
                                          VerticalAlignment="Top"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                          Style="{StaticResource JsonTreeExpanderStyle}" />

                            <Border x:Name="HeaderBorder"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="0,1,0,1"
                                    Padding="6,4"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ContentPresenter x:Name="PART_Header"
                                                  ContentSource="Header"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Border>

                            <ItemsPresenter x:Name="ItemsHost"
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Margin="18,1,0,0" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#F6F9FD" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#EEF4FF" />
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="#D7E4FB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
            <Border Padding="2"
                    HorizontalAlignment="Left"
                    Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel Orientation="Horizontal">
                    <ToggleButton x:Name="TreeButton"
                                  IsChecked="True"
                                  Style="{StaticResource SegmentedToggleButtonStyle}"
                                  Click="TreeButton_Click"
                                  Content="树视图" />
                    <ToggleButton x:Name="RawButton"
                                  Style="{StaticResource SegmentedToggleButtonStyle}"
                                  Click="RawButton_Click"
                                  Content="原文" />
                </StackPanel>
            </Border>

            <Border DockPanel.Dock="Right"
                    Padding="10,4"
                    Margin="8,0,0,0"
                    Background="{StaticResource AccentSoftBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <TextBlock x:Name="SummaryTextBlock"
                           Foreground="{StaticResource AccentBrush}"
                           Text="JSON" />
            </Border>
        </DockPanel>

        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <TreeView x:Name="JsonTree"
                          Padding="12,10,12,12"
                          Background="Transparent"
                          BorderThickness="0"
                          ItemContainerStyle="{StaticResource JsonTreeItemStyle}"
                          PreviewMouseRightButtonDown="JsonTree_PreviewMouseRightButtonDown">
                    <TreeView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="展开全部" Click="ExpandAll_Click" />
                            <MenuItem Header="折叠全部" Click="CollapseAll_Click" />
                            <Separator />
                            <MenuItem Header="复制 JSON" Click="CopyJson_Click" />
                            <MenuItem Header="复制键名" Click="CopySelectedKey_Click" />
                            <MenuItem Header="复制键值" Click="CopySelectedValue_Click" />
                            <MenuItem Header="复制路径" Click="CopySelectedPath_Click" />
                        </ContextMenu>
                    </TreeView.ContextMenu>
                </TreeView>
                <controls:HttpSyntaxTextBox x:Name="FallbackViewer"
                                            Visibility="Collapsed"
                                            SourceText="{Binding JsonText, RelativeSource={RelativeSource AncestorType=controls:JsonTreeViewControl}}"
                                            HighlightMode="Json">
                    <controls:HttpSyntaxTextBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="复制 JSON" Click="CopyJson_Click" />
                        </ContextMenu>
                    </controls:HttpSyntaxTextBox.ContextMenu>
                </controls:HttpSyntaxTextBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
