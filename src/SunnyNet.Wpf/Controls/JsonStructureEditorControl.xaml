<UserControl x:Class="SunnyNet.Wpf.Controls.JsonStructureEditorControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="JsonMiniButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="JsonEditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#1F2D3D" />
            <Setter Property="CaretBrush" Value="#1E50C8" />
            <Setter Property="FontFamily" Value="Consolas, Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="JsonValueTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource JsonEditorTextBoxStyle}">
            <Setter Property="AcceptsReturn" Value="False" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="MaxHeight" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStringValue}" Value="True">
                    <Setter Property="AcceptsReturn" Value="True" />
                    <Setter Property="TextWrapping" Value="Wrap" />
                    <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
                    <Setter Property="MaxHeight" Value="78" />
                    <Setter Property="VerticalContentAlignment" Value="Top" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="JsonNodeRowStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Margin="4,1" CornerRadius="5" Background="{TemplateBinding Background}" BorderBrush="#CFE0FF" BorderThickness="0">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F6FAFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EAF2FF" />
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="#DDE7F2" BorderThickness="1" CornerRadius="8" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Margin="12,0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="214" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="156" />
                </Grid.ColumnDefinitions>
                <TextBlock Foreground="#7B8CA4" FontSize="12" Text="键名" />
                <TextBlock Grid.Column="1" Foreground="#7B8CA4" FontSize="12" Text="值" />
                <TextBlock Grid.Column="2" HorizontalAlignment="Right" Foreground="#7B8CA4" FontSize="12" Text="操作" />
            </Grid>

            <ListBox x:Name="JsonNodeListBox"
                     Grid.Row="1"
                     Margin="6,0,6,8"
                     BorderThickness="0"
                     Background="White"
                     ItemContainerStyle="{StaticResource JsonNodeRowStyle}"
                     AllowDrop="True"
                     SelectionChanged="JsonNodeListBox_SelectionChanged"
                     DragEnter="JsonNodeListBox_DragOver"
                     DragOver="JsonNodeListBox_DragOver"
                     DragLeave="JsonNodeListBox_DragLeave"
                     Drop="JsonNodeListBox_Drop"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.CacheLength="1,1"
                     VirtualizingPanel.CacheLengthUnit="Page"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ContextMenu>
                    <ContextMenu Opened="JsonContextMenu_Opened">
                        <MenuItem x:Name="AddRootChildMenuItem"
                                  Header="新增根节点"
                                  Click="AddRootChild_Click" />
                        <MenuItem Header="展开全部" Click="ExpandAll_Click" />
                        <MenuItem Header="折叠全部" Click="CollapseAll_Click" />
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid MinHeight="30" Margin="0"
                              AllowDrop="True"
                              PreviewMouseLeftButtonDown="JsonNodeRow_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="JsonNodeRow_PreviewMouseMove"
                              DragEnter="JsonNodeRow_DragOver"
                              DragOver="JsonNodeRow_DragOver"
                              DragLeave="JsonNodeRow_DragLeave"
                              Drop="JsonNodeRow_Drop">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="214" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="156" />
                            </Grid.ColumnDefinitions>

                            <Border Height="2" Margin="4,0" VerticalAlignment="Top" Background="#1E78FF" Panel.ZIndex="3">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowDropBefore}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <Border Height="2" Margin="4,0" VerticalAlignment="Bottom" Background="#1E78FF" Panel.ZIndex="3">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowDropAfter}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <Grid Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Width="{Binding Indent}" MinWidth="0">
                                    <Line X1="10" Y1="0" X2="10" Y2="36" Stroke="#AEBFD2" StrokeDashArray="2,3" StrokeThickness="1" HorizontalAlignment="Right" Margin="0,0,8,0" />
                                </Grid>
                                <Grid Grid.Column="1">
                                    <Line X1="0" Y1="15" X2="16" Y2="15" Stroke="#AEBFD2" StrokeDashArray="2,3" StrokeThickness="1" />
                                    <Button Width="16" Height="16" Padding="0" Background="Transparent" BorderThickness="0" Click="ToggleNode_Click" CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Hidden" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanToggle}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Path Width="7" Height="7" Fill="#6C7F95" Stretch="Uniform" Data="M 0 0 L 7 3.5 L 0 7 Z">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="90" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Button>
                                </Grid>
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#9AAABD" Cursor="SizeAll" Text="⋮" ToolTip="拖动调整同级顺序" />
                                <TextBox Grid.Column="3" Style="{StaticResource JsonEditorTextBoxStyle}" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" LostFocus="JsonNodeChanged" />
                            </Grid>

                            <TextBox Grid.Column="1" Style="{StaticResource JsonValueTextBoxStyle}" Foreground="{Binding ValueBrush}" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" GotKeyboardFocus="JsonValueTextBox_GotKeyboardFocus" LostFocus="JsonNodeChanged" KeyDown="JsonValueTextBox_KeyDown" />

                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <ComboBox Width="34" Height="24" Padding="0" FontSize="11" SelectedValue="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Tag" DropDownClosed="JsonTypeDropDownClosed" ToolTip="切换节点类型">
                                    <ComboBoxItem Content="S" Tag="string" />
                                    <ComboBoxItem Content="#" Tag="number" />
                                    <ComboBoxItem Content="B" Tag="bool" />
                                    <ComboBoxItem Content="N" Tag="null" />
                                    <ComboBoxItem Content="{}" Tag="object" />
                                    <ComboBoxItem Content="[]" Tag="array" />
                                </ComboBox>
                                <Button Style="{StaticResource JsonMiniButtonStyle}" Content="+" IsEnabled="{Binding AllowCreateNodes, ElementName=Root}" ToolTip="添加子节点" Click="AddChild_Click" CommandParameter="{Binding}" />
                                <Button Style="{StaticResource JsonMiniButtonStyle}" Content="⧉" IsEnabled="{Binding AllowCreateNodes, ElementName=Root}" ToolTip="复制节点" Click="DuplicateNode_Click" CommandParameter="{Binding}" />
                                <Button Style="{StaticResource JsonMiniButtonStyle}" Content="×" ToolTip="删除节点" Click="RemoveNode_Click" CommandParameter="{Binding}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</UserControl>
