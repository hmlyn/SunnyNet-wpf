<Window x:Class="SunnyNet.Wpf.Windows.OpenSourceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="开源协议"
        Width="940"
        Height="613"
        MinWidth="680"
        MinHeight="520"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="OpenSourceCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Padding" Value="18,14" />
        </Style>

        <Style x:Key="OpenSourceLinkButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,8,10,0" />
        </Style>

        <Style x:Key="OpenSourceMetaTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineHeight" Value="18" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource OpenSourceCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="SunnyNet WPF 版" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource OpenSourceMetaTextStyle}"
                                   Text="作者：hmlyn。基于 SunnyNet Go 核心重绘的 Windows 抓包分析工具，界面层使用 C# + WPF，核心抓包、代理、脚本与协议处理仍由 Go 后端提供。" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Padding="12,6"
                            VerticalAlignment="Top"
                            Background="#EAF4FF"
                            BorderBrush="#CFE2FF"
                            BorderThickness="1"
                            CornerRadius="14">
                        <TextBlock FontSize="12.5"
                                   FontWeight="SemiBold"
                                   Foreground="#1E50C8"
                                   Text="MIT License" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.36*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="0.92*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Border Style="{StaticResource OpenSourceCardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Text="项目地址" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource OpenSourceMetaTextStyle}"
                                       Text="SunnyNet WPF 版由 hmlyn 维护。如果它帮你节省了抓包调试时间，欢迎 Star、Fork，也欢迎提交 Issue 或 Pull Request。" />

                            <WrapPanel Margin="0,4,0,0">
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,8,10,0"
                                        Padding="13,5"
                                        Click="OpenProject_Click"
                                        Content="打开 SunnyNet-wpf 仓库" />
                                <Button Style="{StaticResource OpenSourceLinkButtonStyle}"
                                        Click="CopyProject_Click"
                                        Content="复制项目地址" />
                            </WrapPanel>

                            <Border Margin="0,12,0,0"
                                    Padding="12,9"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    BorderBrush="{StaticResource DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <TextBlock FontFamily="Consolas, Microsoft YaHei UI"
                                           FontSize="12.5"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="https://github.com/hmlyn/SunnyNet-wpf"
                                           TextWrapping="Wrap" />
                            </Border>

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource OpenSourceMetaTextStyle}"
                                       Text="本项目继续使用 SunnyNet Go 核心能力，核心项目地址：" />

                            <WrapPanel Margin="0,0,0,0">
                                <Button Style="{StaticResource OpenSourceLinkButtonStyle}"
                                        Click="OpenCore_Click"
                                        Content="SunnyNet 核心仓库" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,12,0,0" Style="{StaticResource OpenSourceCardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Text="开源协议说明" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource OpenSourceMetaTextStyle}"
                                       Text="SunnyNet WPF 版采用 MIT 协议开源。你可以自由使用、复制、修改、合并、发布、分发或二次开发本项目，但需要保留原始版权声明和协议声明。" />
                            <TextBlock Margin="0,7,0,0"
                                       Style="{StaticResource OpenSourceMetaTextStyle}"
                                       Text="本项目仅用于合法的网络调试、接口分析、测试与技术研究场景。请勿将本工具用于未授权抓包、绕过访问控制、攻击或其它违法用途。" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Text="Copyright (c) hmlyn. Core powered by SunnyNet." />
                        </StackPanel>
                    </Border>

                </StackPanel>

                <Border Grid.Column="2"
                        Padding="0"
                        Background="#08C468"
                        BorderBrush="#07B960"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid Margin="18,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="25"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="支持作者" />
                        <TextBlock Grid.Row="1"
                                   Margin="0,5,0,10"
                                   FontSize="12.5"
                                   Foreground="#E9FFF3"
                                   LineHeight="18"
                                   Text="如果这个工具帮你节省了调试时间，可以请作者喝杯咖啡。每一份赞赏，都会变成继续维护和优化体验的动力。"
                                   TextWrapping="Wrap" />

                        <Border Grid.Row="2"
                                Padding="10"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Background="White"
                                CornerRadius="10">
                            <Grid Width="190" Height="226">
                                <Image x:Name="SponsorImage"
                                       Stretch="Uniform"
                                       Visibility="Collapsed" />
                                <Border x:Name="SponsorMissingPanel"
                                        Padding="18"
                                        Background="#F7FBF9"
                                        BorderBrush="#D9EFE3"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock HorizontalAlignment="Center"
                                                   FontSize="34"
                                                   FontWeight="Bold"
                                                   Foreground="#08A85A"
                                                   Text="￥" />
                                        <TextBlock Margin="0,12,0,0"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1F2D3D"
                                                   Text="赞赏二维码待放入"
                                                   TextAlignment="Center" />
                                        <TextBlock x:Name="SponsorImageHintTextBlock"
                                                   Margin="0,8,0,0"
                                                   FontSize="11.5"
                                                   Foreground="#6B7C93"
                                                   LineHeight="18"
                                                   Text="请将二维码保存为 Resources\SponsorWeChat.png"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <TextBlock Grid.Row="3"
                                   Margin="0,10,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="12.5"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="推荐使用微信支付" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
</Window>
