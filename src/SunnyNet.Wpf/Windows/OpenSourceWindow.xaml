<Window x:Class="SunnyNet.Wpf.Windows.OpenSourceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="开源协议"
        Width="780"
        Height="460"
        MinWidth="680"
        MinHeight="380"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Border Style="{StaticResource CardBorderStyle}">
            <Grid Margin="24,22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource DialogTitleTextStyle}" Text="SunnyNet WPF 版" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource DialogSubtitleTextStyle}"
                               Text="当前版本保留 Go 抓包核心，通过 Windows DLL 供 C# + WPF 界面直接调用，不再启动外部 SunnyNetBridge.exe。" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,24,0,0">
                    <Border Padding="16"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource DividerBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <TextBlock Style="{StaticResource DialogSubtitleTextStyle}"
                                   Text="请仅将本工具用于合法的调试、测试与技术研究场景。原始参考项目与核心库链接如下：" />
                    </Border>

                    <Button Width="340"
                            Margin="0,18,0,0"
                            HorizontalAlignment="Left"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="OpenTools_Click"
                            Content="打开 SunnyNetTools 仓库" />
                    <Button Width="340"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Left"
                            Click="OpenCore_Click"
                            Content="打开 SunnyNet 核心仓库" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Style="{StaticResource CaptionTextStyle}"
                           Text="界面层：C# + WPF；核心层：Go c-shared DLL。" />
            </Grid>
        </Border>
    </Grid>
</Window>
