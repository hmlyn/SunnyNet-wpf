<Window x:Class="SunnyNet.Wpf.Windows.RequestBuilderWindow"
        x:Name="Root"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SunnyNet.Wpf.Controls"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="请求构造器"
        Width="1180"
        Height="720"
        MinWidth="930"
        MinHeight="580"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="BuilderCompactTextBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="TextBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          MinHeight="20"
                                          VerticalAlignment="Center"
                                          Focusable="False" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="TextBoxBorder" Property="Background" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BuilderCodeTextBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="AcceptsTab" Value="True" />
            <Setter Property="FontFamily" Value="Consolas, Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style x:Key="BuilderSmallButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="BuilderTinyButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource BuilderSmallButtonStyle}">
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style x:Key="BuilderDataGridStyle" TargetType="{x:Type DataGrid}">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserSortColumns" Value="False" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource DividerBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="28" />
            <Setter Property="MinRowHeight" Value="28" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SelectionMode" Value="Extended" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style x:Key="BuilderDataGridCellStyle" TargetType="{x:Type DataGridCell}">
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="BuilderDataGridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#F8FAFD" />
            <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style x:Key="HistoryListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
        </Style>

        <DataTemplate x:Key="HistoryItemTemplate">
            <Border Padding="8,5"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="0,0,0,1"
                    ToolTip="{Binding Url}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="54" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Height="22"
                            MinWidth="44"
                            Padding="6,1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="{StaticResource AccentSoftBrush}"
                            CornerRadius="6">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   Text="{Binding Method}" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock FontSize="12.2"
                                   Text="{Binding Url}"
                                   TextTrimming="CharacterEllipsis" />
                        <DockPanel Margin="0,2,0,0">
                            <TextBlock DockPanel.Dock="Left"
                                       FontSize="10.5"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="{Binding DisplayTime}" />
                            <TextBlock Margin="8,0,0,0"
                                       FontSize="10.5"
                                       Foreground="{StaticResource WarningBrush}"
                                       Text="{Binding Notes}"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}">
            <Grid Margin="14,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button MinWidth="76"
                                Style="{StaticResource BuilderSmallButtonStyle}"
                                Click="ClearCurrent_Click"
                                Content="清空" />
                        <Button Margin="8,0,0,0"
                                MinWidth="96"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="12,6"
                                Click="Send_Click"
                                Content="发送请求" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Style="{StaticResource DialogTitleTextStyle}" Text="请求构造器" />
                        <TextBlock x:Name="BuilderSummaryTextBlock"
                                   Margin="0,4,0,0"
                                   Style="{StaticResource DialogSubtitleTextStyle}"
                                   Text="构造 HTTP 请求、从会话回填并重放，发送成功后自动写入历史。" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="118" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="122" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="方法" />
                    <ComboBox x:Name="MethodComboBox"
                              Grid.Column="1"
                              Margin="8,0,14,0"
                              IsEditable="True"
                              KeyUp="MethodComboBox_MethodChanged"
                              LostKeyboardFocus="MethodComboBox_MethodChanged"
                              SelectionChanged="MethodComboBox_MethodChanged"
                              SelectedIndex="0">
                        <ComboBoxItem Content="GET" />
                        <ComboBoxItem Content="POST" />
                        <ComboBoxItem Content="PUT" />
                        <ComboBoxItem Content="PATCH" />
                        <ComboBoxItem Content="DELETE" />
                        <ComboBoxItem Content="HEAD" />
                        <ComboBoxItem Content="OPTIONS" />
                    </ComboBox>

                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="URL" />
                    <TextBox x:Name="UrlTextBox"
                             Grid.Column="3"
                             Margin="8,0,14,0"
                             Style="{StaticResource BuilderCompactTextBoxStyle}" />

                    <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="版本" />
                    <ComboBox x:Name="HttpVersionComboBox"
                              Grid.Column="5"
                              Margin="8,0,0,0"
                              SelectedIndex="1">
                        <ComboBoxItem Content="HTTP/1.0" />
                        <ComboBoxItem Content="HTTP/1.1" />
                        <ComboBoxItem Content="HTTP/1.2" />
                        <ComboBoxItem Content="HTTP/2.0" />
                    </ComboBox>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="252" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="12,9,12,6" LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                MinWidth="54"
                                Style="{StaticResource BuilderTinyButtonStyle}"
                                Click="ClearHistory_Click"
                                Content="清空" />
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   Text="历史记录" />
                    </DockPanel>

                    <ListBox x:Name="HistoryListBox"
                             Grid.Row="1"
                             Margin="8,0,8,8"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource HistoryListBoxItemStyle}"
                             ItemTemplate="{StaticResource HistoryItemTemplate}"
                             ItemsSource="{Binding HistoryItems, ElementName=Root}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             PreviewMouseRightButtonDown="HistoryListBox_PreviewMouseRightButtonDown"
                             SelectionChanged="HistoryListBox_SelectionChanged">
                        <ListBox.ContextMenu>
                            <ContextMenu Opened="HistoryContextMenu_Opened">
                                <MenuItem x:Name="HistoryNotesMenuItem"
                                          Header="备注"
                                          Click="HistoryNotes_Click" />
                                <MenuItem x:Name="HistoryRemoveMenuItem"
                                          Header="移除"
                                          Click="HistoryRemove_Click" />
                                <Separator />
                                <MenuItem Header="清空历史" Click="ClearHistory_Click" />
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="10" HorizontalAlignment="Stretch" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.92*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="1.08*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="12,8,12,4" LastChildFill="True">
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       Text="协议头" />
                        </DockPanel>

                        <TabControl x:Name="HeaderTabControl"
                                    Grid.Row="1"
                                    Margin="10,0,10,10"
                                    SelectionChanged="HeaderTabControl_SelectionChanged">
                            <TabItem Header="原文">
                                <TextBox x:Name="HeadersTextBox"
                                         Style="{StaticResource BuilderCodeTextBoxStyle}" />
                            </TabItem>
                            <TabItem Header="属性">
                                <DataGrid x:Name="HeaderFieldsGrid"
                                          Style="{StaticResource BuilderDataGridStyle}"
                                          CellStyle="{StaticResource BuilderDataGridCellStyle}"
                                          ColumnHeaderStyle="{StaticResource BuilderDataGridHeaderStyle}"
                                          ItemsSource="{Binding HeaderFields, ElementName=Root}"
                                          AllowDrop="True"
                                          Drop="FieldGrid_Drop"
                                          MouseMove="FieldGrid_MouseMove"
                                          PreviewKeyDown="FieldGrid_PreviewKeyDown"
                                          PreviewMouseLeftButtonDown="FieldGrid_PreviewMouseLeftButtonDown"
                                          PreviewMouseRightButtonDown="FieldGrid_PreviewMouseRightButtonDown">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu Opened="FieldGridContextMenu_Opened">
                                            <MenuItem Header="新增" Click="FieldAddMenuItem_Click" />
                                            <MenuItem Header="删除" InputGestureText="Del" Click="FieldDeleteMenuItem_Click" />
                                            <Separator />
                                            <MenuItem Header="上移" InputGestureText="↑" Click="FieldMoveUpMenuItem_Click" />
                                            <MenuItem Header="下移" InputGestureText="↓" Click="FieldMoveDownMenuItem_Click" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="" Width="36" Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <DataGridTextColumn Header="键" Width="0.35*" Binding="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <DataGridTextColumn Header="值" Width="0.65*" Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" Height="10" HorizontalAlignment="Stretch" />

                <Border x:Name="BodySectionBorder" Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="12,8,12,4" LastChildFill="True">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <TextBlock Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Text="输入" />
                                <ComboBox x:Name="BodyFormatComboBox"
                                          Width="92"
                                          SelectedIndex="0"
                                          SelectionChanged="BodyFormatComboBox_SelectionChanged">
                                    <ComboBoxItem Content="文本" />
                                    <ComboBoxItem Content="HEX" />
                                    <ComboBoxItem Content="Base64" />
                                </ComboBox>
                            </StackPanel>
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       Text="Body" />
                        </DockPanel>

                        <TabControl x:Name="BodyTabControl"
                                    Grid.Row="1"
                                    Margin="10,0,10,10"
                                    SelectionChanged="BodyTabControl_SelectionChanged">
                            <TabItem Header="原文">
                                <TextBox x:Name="BodyTextBox"
                                         Style="{StaticResource BuilderCodeTextBoxStyle}"
                                         TextWrapping="Wrap"
                                         HorizontalScrollBarVisibility="Disabled" />
                            </TabItem>
                            <TabItem Header="属性">
                                <DataGrid x:Name="BodyFieldsGrid"
                                          Style="{StaticResource BuilderDataGridStyle}"
                                          CellStyle="{StaticResource BuilderDataGridCellStyle}"
                                          ColumnHeaderStyle="{StaticResource BuilderDataGridHeaderStyle}"
                                          ItemsSource="{Binding BodyFields, ElementName=Root}"
                                          AllowDrop="True"
                                          Drop="FieldGrid_Drop"
                                          MouseMove="FieldGrid_MouseMove"
                                          PreviewKeyDown="FieldGrid_PreviewKeyDown"
                                          PreviewMouseLeftButtonDown="FieldGrid_PreviewMouseLeftButtonDown"
                                          PreviewMouseRightButtonDown="FieldGrid_PreviewMouseRightButtonDown">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu Opened="FieldGridContextMenu_Opened">
                                            <MenuItem Header="新增" Click="FieldAddMenuItem_Click" />
                                            <MenuItem Header="删除" InputGestureText="Del" Click="FieldDeleteMenuItem_Click" />
                                            <Separator />
                                            <MenuItem Header="上移" InputGestureText="↑" Click="FieldMoveUpMenuItem_Click" />
                                            <MenuItem Header="下移" InputGestureText="↓" Click="FieldMoveDownMenuItem_Click" />
                                            <Separator />
                                            <MenuItem Header="按键名排序" Click="FieldSortMenuItem_Click" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="" Width="36" Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <DataGridTextColumn Header="键" Width="0.35*" Binding="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <DataGridTextColumn Header="值" Width="0.65*" Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="JSON">
                                <controls:JsonStructureEditorControl x:Name="BodyJsonEditor" />
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
