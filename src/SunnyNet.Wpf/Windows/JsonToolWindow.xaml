<Window x:Class="SunnyNet.Wpf.Windows.JsonToolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JSON工具"
        Width="1120"
        Height="700"
        MinWidth="900"
        MinHeight="560"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}">
            <DockPanel Margin="18,14" LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        MinWidth="88"
                        Padding="12,5"
                        Click="ClearAll_Click"
                        Content="清空" />
                <StackPanel>
                    <TextBlock Style="{StaticResource DialogTitleTextStyle}" Text="JSON工具" />
                    <TextBlock x:Name="ToolSummaryTextBlock"
                               Margin="0,6,0,0"
                               Style="{StaticResource DialogSubtitleTextStyle}"
                               Text="支持 JSON 解析格式化和 JSON 结构构造。" />
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="0,16,0,0">
                            <TabItem Header="JSON解析">
                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel Margin="14,10" Orientation="Horizontal">
                                    <Button MinWidth="96" Padding="12,5" Click="FormatJson_Click" Content="格式化" />
                                    <Button Margin="8,0,0,0" MinWidth="96" Padding="12,5" Click="MinifyJson_Click" Content="压缩" />
                                    <TextBlock x:Name="JsonParseStatusTextBlock" Margin="14,0,0,0" VerticalAlignment="Center" Style="{StaticResource DialogSubtitleTextStyle}" Text="输入 JSON 后点击解析。" />
                                </StackPanel>
                            </Border>
                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <TextBox x:Name="JsonInputTextBox" Margin="12" AcceptsReturn="True" Background="White" Foreground="{StaticResource TextPrimaryBrush}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" FontFamily="Consolas, Microsoft YaHei UI" TextWrapping="NoWrap" />
                                </Border>
                                <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" />
                                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                    <TextBox x:Name="JsonOutputTextBox" Margin="12" AcceptsReturn="True" Background="White" Foreground="{StaticResource TextPrimaryBrush}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" FontFamily="Consolas, Microsoft YaHei UI" TextWrapping="NoWrap" />
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>

            <TabItem Header="JSON构造器">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Margin="14,10" Orientation="Horizontal">
                            <TextBox x:Name="JsonNodeNameTextBox" Width="150" Height="40" Padding="10,6" Background="White" Foreground="#1F2D3D" CaretBrush="#1E50C8" VerticalContentAlignment="Center" ToolTip="属性名，根数组项可留空" />
                            <ComboBox x:Name="JsonNodeTypeComboBox" Margin="8,0,0,0" Width="110" SelectedIndex="0">
                                <ComboBoxItem Content="string" />
                                <ComboBoxItem Content="number" />
                                <ComboBoxItem Content="bool" />
                                <ComboBoxItem Content="null" />
                                <ComboBoxItem Content="object" />
                                <ComboBoxItem Content="array" />
                            </ComboBox>
                            <TextBox x:Name="JsonNodeValueTextBox" Margin="8,0,0,0" Width="220" Height="40" Padding="10,6" Background="White" Foreground="#1F2D3D" CaretBrush="#1E50C8" VerticalContentAlignment="Center" />
                            <Button Margin="8,0,0,0" MinWidth="88" Padding="12,5" Click="AddJsonNode_Click" Content="新增节点" />
                            <Button Margin="8,0,0,0" MinWidth="88" Padding="12,5" Click="RemoveJsonNode_Click" Content="删除节点" />
                            <Button Margin="8,0,0,0" MinWidth="88" Padding="12,5" Click="ClearJsonBuilder_Click" Content="清空" />
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.9*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="1.1*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <TreeView x:Name="JsonBuilderTreeView" Margin="12" SelectedItemChanged="JsonBuilderTreeView_SelectedItemChanged" />
                        </Border>
                        <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" />
                        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                            <TextBox x:Name="JsonBuilderOutputTextBox" Margin="12" AcceptsReturn="True" IsReadOnly="True" Background="White" Foreground="{StaticResource TextPrimaryBrush}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" FontFamily="Consolas, Microsoft YaHei UI" TextWrapping="NoWrap" />
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>        </TabControl>
    </Grid>
</Window>

