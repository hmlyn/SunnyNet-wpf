<Window x:Class="SunnyNet.Wpf.Windows.JsonToolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JSON工具"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="600"
        Background="#F5F7FB"
        Foreground="#1F2D3D"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
        <Style x:Key="JsonToolButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="JsonCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE7F2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="JsonTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2D3D" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="JsonSubtitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7B8CA4" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="JsonMiniButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="JsonEditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#1F2D3D" />
            <Setter Property="CaretBrush" Value="#1E50C8" />
            <Setter Property="FontFamily" Value="Consolas, Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="JsonValueTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource JsonEditorTextBoxStyle}">
            <Setter Property="AcceptsReturn" Value="False" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="MaxHeight" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStringValue}" Value="True">
                    <Setter Property="AcceptsReturn" Value="True" />
                    <Setter Property="TextWrapping" Value="Wrap" />
                    <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
                    <Setter Property="MaxHeight" Value="78" />
                    <Setter Property="VerticalContentAlignment" Value="Top" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="JsonTypeBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Background" Value="#EEF4FF" />
            <Setter Property="BorderBrush" Value="#D8E4FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Type}" Value="string">
                    <Setter Property="Background" Value="#EAF8EF" />
                    <Setter Property="BorderBrush" Value="#CBEFD8" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="number">
                    <Setter Property="Background" Value="#FFF0EC" />
                    <Setter Property="BorderBrush" Value="#FFD2C5" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="bool">
                    <Setter Property="Background" Value="#EDF3FF" />
                    <Setter Property="BorderBrush" Value="#CFE0FF" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="null">
                    <Setter Property="Background" Value="#F2F4F7" />
                    <Setter Property="BorderBrush" Value="#DDE3EA" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="object">
                    <Setter Property="Background" Value="#FFF6E8" />
                    <Setter Property="BorderBrush" Value="#FFE1AD" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="array">
                    <Setter Property="Background" Value="#F0F5FF" />
                    <Setter Property="BorderBrush" Value="#CCDDFC" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="JsonNodeRowStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Margin="6,1" CornerRadius="5" Background="{TemplateBinding Background}" BorderBrush="#CFE0FF" BorderThickness="0">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F6FAFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EAF2FF" />
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource JsonCardBorderStyle}">
            <DockPanel Margin="16,12" LastChildFill="True">
                <Button DockPanel.Dock="Right" Style="{StaticResource JsonToolButtonStyle}" Click="ClearAll_Click" Content="清空" />
                <StackPanel>
                    <TextBlock Style="{StaticResource JsonTitleTextStyle}" Text="JSON工具" />
                    <TextBlock x:Name="ToolSummaryTextBlock" Margin="0,5,0,0" Style="{StaticResource JsonSubtitleTextStyle}" Text="左侧编辑原文，右侧以纯 WPF 节点表格编辑 JSON 结构。" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.02*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1.18*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource JsonCardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="12,10" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Style="{StaticResource JsonToolButtonStyle}" Click="FormatJson_Click" Content="格式化" />
                            <Button Style="{StaticResource JsonToolButtonStyle}" Click="MinifyJson_Click" Content="压缩" />
                            <Button Style="{StaticResource JsonToolButtonStyle}" Click="ParseToTree_Click" Content="解析到树" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Foreground="#1F2D3D" Text="JSON 原文" />
                            <TextBlock x:Name="JsonParseStatusTextBlock" Margin="0,3,0,0" Style="{StaticResource JsonSubtitleTextStyle}" Text="输入 JSON 后可格式化或解析到右侧结构。" />
                        </StackPanel>
                    </DockPanel>
                    <Border Grid.Row="1" Margin="12,0,12,12" BorderBrush="#DDE7F2" BorderThickness="1" CornerRadius="8" Background="White">
                        <TextBox x:Name="JsonInputTextBox" Margin="10" AcceptsReturn="True" Background="White" BorderThickness="0" Foreground="#1F2D3D" CaretBrush="#1E50C8" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" FontFamily="Consolas, Microsoft YaHei UI" FontSize="13" TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" Background="Transparent" />

            <Border Grid.Column="2" Style="{StaticResource JsonCardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="12,10" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Style="{StaticResource JsonToolButtonStyle}" Click="TreeToText_Click" Content="同步原文" />
                            <Button Style="{StaticResource JsonToolButtonStyle}" Click="ExpandAll_Click" Content="展开" />
                            <Button Style="{StaticResource JsonToolButtonStyle}" Click="CollapseAll_Click" Content="折叠" />
                            <Button Style="{StaticResource JsonToolButtonStyle}" Click="AddRootChild_Click" Content="新增" />
                        </StackPanel>
                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#1F2D3D" Text="JSON 结构编辑器" />
                    </DockPanel>

                    <Border Grid.Row="1" Margin="12,0,12,12" BorderBrush="#DDE7F2" BorderThickness="1" CornerRadius="8" Background="White">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="32" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Margin="12,0" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="214" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="156" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="#7B8CA4" FontSize="12" Text="键名" />
                                <TextBlock Grid.Column="1" Foreground="#7B8CA4" FontSize="12" Text="值" />
                                <TextBlock Grid.Column="2" HorizontalAlignment="Right" Foreground="#7B8CA4" FontSize="12" Text="操作" />
                            </Grid>
                            <ListBox x:Name="JsonNodeListBox"
                                     Grid.Row="1"
                                     Margin="6,0,6,8"
                                     BorderThickness="0"
                                     Background="White"
                                     ItemContainerStyle="{StaticResource JsonNodeRowStyle}"
                                     AllowDrop="True"
                                     SelectionChanged="JsonNodeListBox_SelectionChanged"
                                     DragEnter="JsonNodeListBox_DragOver"
                                     DragOver="JsonNodeListBox_DragOver"
                                     DragLeave="JsonNodeListBox_DragLeave"
                                     Drop="JsonNodeListBox_Drop"
                                     ScrollViewer.CanContentScroll="True"
                                     VirtualizingPanel.CacheLength="1,1"
                                     VirtualizingPanel.CacheLengthUnit="Page"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.ScrollUnit="Pixel"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid MinHeight="30" Margin="0"
                                              AllowDrop="True"
                                              PreviewMouseLeftButtonDown="JsonNodeRow_PreviewMouseLeftButtonDown"
                                              PreviewMouseMove="JsonNodeRow_PreviewMouseMove"
                                              DragEnter="JsonNodeRow_DragOver"
                                              DragOver="JsonNodeRow_DragOver"
                                              DragLeave="JsonNodeRow_DragLeave"
                                              Drop="JsonNodeRow_Drop">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="214" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="156" />
                                            </Grid.ColumnDefinitions>

                                            <Border Height="2" Margin="4,0" VerticalAlignment="Top" Background="#1E78FF" Panel.ZIndex="3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ShowDropBefore}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>

                                            <Border Height="2" Margin="4,0" VerticalAlignment="Bottom" Background="#1E78FF" Panel.ZIndex="3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ShowDropAfter}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>

                                            <Grid Grid.Column="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="20" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Width="{Binding Indent}" MinWidth="0">
                                                    <Line X1="10" Y1="0" X2="10" Y2="36" Stroke="#AEBFD2" StrokeDashArray="2,3" StrokeThickness="1" HorizontalAlignment="Right" Margin="0,0,8,0" />
                                                </Grid>
                                                <Grid Grid.Column="1">
                                                    <Line X1="0" Y1="15" X2="16" Y2="15" Stroke="#AEBFD2" StrokeDashArray="2,3" StrokeThickness="1" />
                                                    <Button Width="16" Height="16" Padding="0" Background="Transparent" BorderThickness="0" Click="ToggleNode_Click" CommandParameter="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Visibility" Value="Hidden" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CanToggle}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <Path Width="7" Height="7" Fill="#6C7F95" Stretch="Uniform" Data="M 0 0 L 7 3.5 L 0 7 Z">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                            <Setter Property="RenderTransform">
                                                                                <Setter.Value>
                                                                                    <RotateTransform Angle="90" />
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Button>
                                                </Grid>
                                                <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#9AAABD" Cursor="SizeAll" Text="⋮" ToolTip="拖动调整同级顺序" />
                                                <TextBox Grid.Column="3" Style="{StaticResource JsonEditorTextBoxStyle}" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" LostFocus="JsonNodeChanged" />
                                            </Grid>

                                            <TextBox Grid.Column="1" Style="{StaticResource JsonValueTextBoxStyle}" Foreground="{Binding ValueBrush}" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" GotKeyboardFocus="JsonValueTextBox_GotKeyboardFocus" LostFocus="JsonNodeChanged" KeyDown="JsonValueTextBox_KeyDown" />

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <ComboBox Width="34" Height="24" Padding="0" FontSize="11" SelectedValue="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Tag" DropDownClosed="JsonTypeDropDownClosed" ToolTip="切换节点类型">
                                                    <ComboBoxItem Content="S" Tag="string" />
                                                    <ComboBoxItem Content="#" Tag="number" />
                                                    <ComboBoxItem Content="B" Tag="bool" />
                                                    <ComboBoxItem Content="N" Tag="null" />
                                                    <ComboBoxItem Content="{}" Tag="object" />
                                                    <ComboBoxItem Content="[]" Tag="array" />
                                                </ComboBox>
                                                <Button Style="{StaticResource JsonMiniButtonStyle}" Content="+" ToolTip="添加子节点" Click="AddChild_Click" CommandParameter="{Binding}" />
                                                <Button Style="{StaticResource JsonMiniButtonStyle}" Content="⧉" ToolTip="复制节点" Click="DuplicateNode_Click" CommandParameter="{Binding}" />
                                                <Button Style="{StaticResource JsonMiniButtonStyle}" Content="×" ToolTip="删除节点" Click="RemoveNode_Click" CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>




