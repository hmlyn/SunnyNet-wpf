<Window x:Class="SunnyNet.Wpf.Windows.RulesCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="规则中心"
        Width="1140"
        Height="704"
        MinWidth="980"
        MinHeight="590"
        Background="#EEF5FB"
        Foreground="{StaticResource TextPrimaryBrush}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="RulesToolbarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D3DFEC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F2F7FF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#9EC8F5" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E7F1FF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#A9B5C4" />
                                <Setter Property="Cursor" Value="Arrow" />
                                <Setter TargetName="Root" Property="Background" Value="#F7F9FC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RulesPrimaryToolbarButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource RulesToolbarButtonStyle}">
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="Background" Value="#EAF3FF" />
            <Setter Property="BorderBrush" Value="#B8D7F8" />
            <Setter Property="Foreground" Value="#1063B8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="RulesDangerToolbarButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource RulesToolbarButtonStyle}">
            <Setter Property="Foreground" Value="#CF3F32" />
        </Style>

        <Style x:Key="RulesNavToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F1F6FC" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E5F1FF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C7DFF8" />
                                <Setter Property="Foreground" Value="#005EA8" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.56" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RulesSubNavToggleButtonStyle" TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource RulesNavToggleButtonStyle}">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="18,0,0,4" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="RulesSummaryCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#DCE6F1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <Style x:Key="RulesDataGridStyle" TargetType="{x:Type DataGrid}" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Vertical" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E4EAF2" />
            <Setter Property="VerticalGridLinesBrush" Value="#E4EAF2" />
            <Setter Property="RowHeight" Value="25" />
            <Setter Property="MinRowHeight" Value="25" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="BorderBrush" Value="#E1E8F0" />
            <Setter Property="BorderThickness" Value="1,1,0,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                        <Setter Property="Height" Value="31" />
                        <Setter Property="Padding" Value="12,4" />
                        <Setter Property="Background" Value="#FAFBFD" />
                        <Setter Property="Foreground" Value="#5F6F83" />
                        <Setter Property="FontWeight" Value="Normal" />
                        <Setter Property="BorderBrush" Value="#E1E8F0" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
                        <Setter Property="Padding" Value="12,2" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="BorderBrush" Value="#E4EAF2" />
                        <Setter Property="BorderThickness" Value="0,0,1,0" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E6F2FD" />
                                <Setter Property="Foreground" Value="#111827" />
                                <Setter Property="BorderBrush" Value="#D7EAFB" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Setter Property="MinHeight" Value="25" />
                        <Setter Property="Background" Value="#FFFFFF" />
                        <Setter Property="BorderBrush" Value="#E4EAF2" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5FAFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E6F2FD" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RuleEnableCheckBoxStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Border x:Name="Box"
                                Width="16"
                                Height="16"
                                Background="#E9EEF5"
                                BorderBrush="#C8D6E6"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Path x:Name="CheckMark"
                                  Data="M3.6,8.2 L6.6,11.0 L12.4,4.8"
                                  Stroke="#FFFFFF"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Visibility="Collapsed" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#4AA3F0" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="#2F80D8" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#73B5EF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Box" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="RuleEnableHeaderTemplate">
            <TextBlock Text="" />
        </DataTemplate>

        <DataTemplate x:Key="RuleEnableCellTemplate">
            <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Click="RuleEnableCheckBox_Click"
                      Style="{StaticResource RuleEnableCheckBoxStyle}" />
        </DataTemplate>

        <Style x:Key="RuleEnableCellStyle" TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#E4EAF2" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E6F2FD" />
                    <Setter Property="BorderBrush" Value="#D7EAFB" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Border Background="#FFFFFF"
                BorderBrush="#CBD8E6"
                BorderThickness="1"
                CornerRadius="9">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="28" />
                </Grid.RowDefinitions>

                <DockPanel Margin="14,0"
                           LastChildFill="False">
                    <StackPanel VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#08213D"
                                   Text="规则中心" />
                        <TextBlock x:Name="PageTitleTextBlock"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="#005EA8"
                                   Text="请求断点" />
                        <TextBlock x:Name="PageSubtitleTextBlock"
                                   Margin="10,1,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="命中 URL、参数、协议头或包体后自动进入上行/下行断点编辑。" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Margin="0,0,7,0" Fill="#C5D0DE" />
                        <Ellipse Width="10" Height="10" Margin="0,0,7,0" Fill="#C5D0DE" />
                        <Ellipse Width="10" Height="10" Fill="#C5D0DE" />
                    </StackPanel>
                </DockPanel>

                <Border Grid.Row="1"
                        BorderBrush="#DDE6EF"
                        BorderThickness="0,1,0,1">
                    <DockPanel Margin="14,0"
                               LastChildFill="False">
                        <StackPanel VerticalAlignment="Center"
                                    Orientation="Horizontal">
                            <Button x:Name="AddRuleButton"
                                    Click="AddCurrentRule_Click"
                                    Content="添加断点"
                                    Style="{StaticResource RulesPrimaryToolbarButtonStyle}" />
                            <Button x:Name="EditRuleButton"
                                    Click="EditSelectedRule_Click"
                                    Content="编辑"
                                    Style="{StaticResource RulesToolbarButtonStyle}" />
                            <Button x:Name="RemoveRuleButton"
                                    Click="RemoveSelectedRule_Click"
                                    Content="删除"
                                    Style="{StaticResource RulesDangerToolbarButtonStyle}" />
                        </StackPanel>
                        <TextBox x:Name="RuleSearchTextBox"
                                 DockPanel.Dock="Right"
                                 Width="230"
                                 Height="30"
                                 VerticalAlignment="Center"
                                 Padding="10,5"
                                 VerticalContentAlignment="Center"
                                 Style="{StaticResource {x:Type TextBox}}"
                                 TextChanged="RuleSearchTextBox_TextChanged"
                                 ToolTip="搜索当前规则列表" />
                    </DockPanel>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="176" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="#FAFCFF">
                        <Grid Margin="14,14,8,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="请求规则" />

                            <ScrollViewer Grid.Row="2"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <ToggleButton x:Name="RequestBreakpointNavButton"
                                                  Tag="请求断点"
                                                  Click="NavigationButton_Click"
                                                  Style="{StaticResource RulesNavToggleButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock VerticalAlignment="Center"
                                                           FontSize="12"
                                                           Text="●" />
                                                <TextBlock Margin="7,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Text="请求断点" />
                                            </StackPanel>
                                            <TextBlock x:Name="RequestBreakpointCountTextBlock"
                                                       Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="0" />
                                        </Grid>
                                    </ToggleButton>

                                    <Border Height="8" />

                                    <Grid Margin="10,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock VerticalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="#0B2A4A"
                                                       Text="●" />
                                            <TextBlock Margin="7,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Text="请求屏蔽" />
                                        </StackPanel>
                                        <TextBlock x:Name="BlockTotalCountTextBlock"
                                                   Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Text="0" />
                                    </Grid>

                                    <ToggleButton x:Name="HttpBlockNavButton"
                                                  Tag="HTTP屏蔽"
                                                  Click="NavigationButton_Click"
                                                  Style="{StaticResource RulesSubNavToggleButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="HTTP" />
                                            <TextBlock x:Name="HttpBlockCountTextBlock"
                                                       Grid.Column="1"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="0" />
                                        </Grid>
                                    </ToggleButton>
                                    <ToggleButton x:Name="WebSocketBlockNavButton"
                                                  Tag="WebSocket屏蔽"
                                                  Click="NavigationButton_Click"
                                                  Style="{StaticResource RulesSubNavToggleButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="WebSocket" />
                                            <TextBlock x:Name="WebSocketBlockCountTextBlock"
                                                       Grid.Column="1"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="0" />
                                        </Grid>
                                    </ToggleButton>
                                    <ToggleButton x:Name="TcpBlockNavButton"
                                                  Tag="TCP屏蔽"
                                                  Click="NavigationButton_Click"
                                                  Style="{StaticResource RulesSubNavToggleButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="TCP" />
                                            <TextBlock x:Name="TcpBlockCountTextBlock"
                                                       Grid.Column="1"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="0" />
                                        </Grid>
                                    </ToggleButton>
                                    <ToggleButton x:Name="UdpBlockNavButton"
                                                  Tag="UDP屏蔽"
                                                  Click="NavigationButton_Click"
                                                  Style="{StaticResource RulesSubNavToggleButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="UDP" />
                                            <TextBlock x:Name="UdpBlockCountTextBlock"
                                                       Grid.Column="1"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="0" />
                                        </Grid>
                                    </ToggleButton>

                                    <Border Height="8" />

                                    <ToggleButton x:Name="RequestRewriteNavButton"
                                                  Tag="请求重写"
                                                  Click="NavigationButton_Click"
                                                  Style="{StaticResource RulesNavToggleButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock VerticalAlignment="Center"
                                                           FontSize="12"
                                                           Text="●" />
                                                <TextBlock Margin="7,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Text="请求重写" />
                                            </StackPanel>
                                            <TextBlock x:Name="RequestRewriteCountTextBlock"
                                                       Grid.Column="1"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="0" />
                                        </Grid>
                                    </ToggleButton>

                                    <ToggleButton x:Name="RequestMappingNavButton"
                                                  Tag="请求映射"
                                                  Click="NavigationButton_Click"
                                                  Style="{StaticResource RulesNavToggleButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock VerticalAlignment="Center"
                                                           FontSize="12"
                                                           Text="●" />
                                                <TextBlock Margin="7,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Text="请求映射" />
                                            </StackPanel>
                                            <TextBlock x:Name="RequestMappingCountTextBlock"
                                                       Grid.Column="1"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="0" />
                                        </Grid>
                                    </ToggleButton>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="#DDE6EF" />

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="96" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <UniformGrid Margin="12,10,12,8" Columns="3">
                            <Border Style="{StaticResource RulesSummaryCardStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Text="全部" />
                                    <TextBlock x:Name="SummaryTotalTextBlock"
                                               Margin="0,4,0,0"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="#0B2A4A"
                                               LineHeight="26"
                                               Text="0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource RulesSummaryCardStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Text="已启用" />
                                    <TextBlock x:Name="SummaryEnabledTextBlock"
                                               Margin="0,4,0,0"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="#17A34A"
                                               LineHeight="26"
                                               Text="0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource RulesSummaryCardStyle}">
                                <StackPanel>
                                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Text="未保存" />
                                    <TextBlock x:Name="SummaryDirtyTextBlock"
                                               Margin="0,4,0,0"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="#F97316"
                                               LineHeight="26"
                                               Text="0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Grid.Row="1" Margin="12,0,0,0">
                            <DataGrid x:Name="BreakpointRulesGrid"
                                      ItemsSource="{Binding InterceptRuleItems}"
                                      MouseDoubleClick="RulesGrid_MouseDoubleClick"
                                      SelectionChanged="RulesGrid_SelectionChanged"
                                      Style="{StaticResource RulesDataGridStyle}"
                                      Visibility="Collapsed">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn HeaderTemplate="{StaticResource RuleEnableHeaderTemplate}"
                                                            CellTemplate="{StaticResource RuleEnableCellTemplate}"
                                                            CellStyle="{StaticResource RuleEnableCellStyle}"
                                                            Width="42" />
                                    <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="130" />
                                    <DataGridTextColumn Header="方向" Binding="{Binding Direction}" Width="80" />
                                    <DataGridTextColumn Header="匹配范围" Binding="{Binding Target}" Width="110" />
                                    <DataGridTextColumn Header="匹配方式" Binding="{Binding Operator}" Width="88" />
                                    <DataGridTextColumn Header="匹配值" Binding="{Binding Value}" Width="2*" />
                                    <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="170" />
                                    <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <DataGrid x:Name="BlockRulesGrid"
                                      ItemsSource="{Binding RequestBlockRules}"
                                      MouseDoubleClick="RulesGrid_MouseDoubleClick"
                                      SelectionChanged="RulesGrid_SelectionChanged"
                                      Style="{StaticResource RulesDataGridStyle}"
                                      Visibility="Collapsed">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn HeaderTemplate="{StaticResource RuleEnableHeaderTemplate}"
                                                            CellTemplate="{StaticResource RuleEnableCellTemplate}"
                                                            CellStyle="{StaticResource RuleEnableCellStyle}"
                                                            Width="42" />
                                    <DataGridTextColumn Header="别名" Binding="{Binding Name}" Width="128" />
                                    <DataGridTextColumn Header="方法" Binding="{Binding Method}" Width="66" />
                                    <DataGridTextColumn Header="匹配" Binding="{Binding UrlMatchType}" Width="68" />
                                    <DataGridTextColumn Header="Url" Binding="{Binding UrlPattern}" Width="260" />
                                    <DataGridTextColumn Header="动作" Binding="{Binding Action}" Width="92" />
                                    <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="140" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <DataGrid x:Name="WebSocketBlockRulesGrid"
                                      ItemsSource="{Binding WebSocketBlockRules}"
                                      MouseDoubleClick="RulesGrid_MouseDoubleClick"
                                      SelectionChanged="RulesGrid_SelectionChanged"
                                      Style="{StaticResource RulesDataGridStyle}"
                                      Visibility="Collapsed">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn HeaderTemplate="{StaticResource RuleEnableHeaderTemplate}"
                                                            CellTemplate="{StaticResource RuleEnableCellTemplate}"
                                                            CellStyle="{StaticResource RuleEnableCellStyle}"
                                                            Width="42" />
                                    <DataGridTextColumn Header="别名" Binding="{Binding Name}" Width="140" />
                                    <DataGridTextColumn Header="匹配" Binding="{Binding UrlMatchType}" Width="72" />
                                    <DataGridTextColumn Header="Url" Binding="{Binding UrlPattern}" Width="360" />
                                    <DataGridTextColumn Header="动作" Binding="{Binding Action}" Width="120" />
                                    <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="180" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <DataGrid x:Name="TcpBlockRulesGrid"
                                      ItemsSource="{Binding TcpBlockRules}"
                                      MouseDoubleClick="RulesGrid_MouseDoubleClick"
                                      SelectionChanged="RulesGrid_SelectionChanged"
                                      Style="{StaticResource RulesDataGridStyle}"
                                      Visibility="Collapsed">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn HeaderTemplate="{StaticResource RuleEnableHeaderTemplate}"
                                                            CellTemplate="{StaticResource RuleEnableCellTemplate}"
                                                            CellStyle="{StaticResource RuleEnableCellStyle}"
                                                            Width="42" />
                                    <DataGridTextColumn Header="别名" Binding="{Binding Name}" Width="140" />
                                    <DataGridTextColumn Header="协议" Binding="{Binding Method}" Width="86" />
                                    <DataGridTextColumn Header="匹配" Binding="{Binding UrlMatchType}" Width="72" />
                                    <DataGridTextColumn Header="地址" Binding="{Binding UrlPattern}" Width="360" />
                                    <DataGridTextColumn Header="动作" Binding="{Binding Action}" Width="120" />
                                    <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="180" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <DataGrid x:Name="UdpBlockRulesGrid"
                                      ItemsSource="{Binding UdpBlockRules}"
                                      MouseDoubleClick="RulesGrid_MouseDoubleClick"
                                      SelectionChanged="RulesGrid_SelectionChanged"
                                      Style="{StaticResource RulesDataGridStyle}"
                                      Visibility="Collapsed">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn HeaderTemplate="{StaticResource RuleEnableHeaderTemplate}"
                                                            CellTemplate="{StaticResource RuleEnableCellTemplate}"
                                                            CellStyle="{StaticResource RuleEnableCellStyle}"
                                                            Width="42" />
                                    <DataGridTextColumn Header="别名" Binding="{Binding Name}" Width="140" />
                                    <DataGridTextColumn Header="匹配" Binding="{Binding UrlMatchType}" Width="72" />
                                    <DataGridTextColumn Header="地址" Binding="{Binding UrlPattern}" Width="380" />
                                    <DataGridTextColumn Header="动作" Binding="{Binding Action}" Width="120" />
                                    <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="180" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <DataGrid x:Name="RewriteRulesGrid"
                                      ItemsSource="{Binding RequestRewriteRules}"
                                      MouseDoubleClick="RulesGrid_MouseDoubleClick"
                                      SelectionChanged="RulesGrid_SelectionChanged"
                                      Style="{StaticResource RulesDataGridStyle}"
                                      Visibility="Collapsed">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn HeaderTemplate="{StaticResource RuleEnableHeaderTemplate}"
                                                            CellTemplate="{StaticResource RuleEnableCellTemplate}"
                                                            CellStyle="{StaticResource RuleEnableCellStyle}"
                                                            Width="58" />
                                    <DataGridTextColumn Header="别名" Binding="{Binding Name}" Width="150" />
                                    <DataGridTextColumn Header="方法" Binding="{Binding Method}" Width="82" />
                                    <DataGridTextColumn Header="匹配" Binding="{Binding UrlMatchType}" Width="82" />
                                    <DataGridTextColumn Header="Url" Binding="{Binding UrlPattern}" Width="300" />
                                    <DataGridTextColumn Header="方向" Binding="{Binding Direction}" Width="82" />
                                    <DataGridTextColumn Header="动作链" Binding="{Binding Summary}" Width="260" />
                                    <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="180" />
                                    <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="100" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <DataGrid x:Name="MappingRulesGrid"
                                      ItemsSource="{Binding RequestMappingRules}"
                                      MouseDoubleClick="RulesGrid_MouseDoubleClick"
                                      SelectionChanged="RulesGrid_SelectionChanged"
                                      Style="{StaticResource RulesDataGridStyle}"
                                      Visibility="Collapsed">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn HeaderTemplate="{StaticResource RuleEnableHeaderTemplate}"
                                                            CellTemplate="{StaticResource RuleEnableCellTemplate}"
                                                            CellStyle="{StaticResource RuleEnableCellStyle}"
                                                            Width="58" />
                                    <DataGridTextColumn Header="别名" Binding="{Binding Name}" Width="150" />
                                    <DataGridTextColumn Header="方法" Binding="{Binding Method}" Width="82" />
                                    <DataGridTextColumn Header="匹配" Binding="{Binding UrlMatchType}" Width="82" />
                                    <DataGridTextColumn Header="Url" Binding="{Binding UrlPattern}" Width="340" />
                                    <DataGridTextColumn Header="映射类型" Binding="{Binding MappingType}" Width="116" />
                                    <DataGridTextColumn Header="内容格式" Binding="{Binding DisplayValueType}" Width="116" />
                                    <DataGridTextColumn Header="目标/内容" Binding="{Binding TargetContent}" Width="430" />
                                    <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="180" />
                                    <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="100" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border x:Name="PlaceholderListPanel"
                                    Background="#FFFFFF"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="PlaceholderTextBlock"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="该规则类型将在下一步接入。" />
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <DockPanel Grid.Row="3"
                           Margin="12,0"
                           LastChildFill="False">
                    <TextBlock x:Name="LeftHintTextBlock"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="双击规则直接编辑，Del 删除所选。" />
                    <TextBlock x:Name="RuleStatusTextBlock"
                               DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="0 条" />
                </DockPanel>
            </Grid>
        </Border>

        <Border x:Name="RuleAlertBorder"
                Panel.ZIndex="10"
                Width="320"
                Margin="0,14,0,0"
                Padding="14,10"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Background="#FEF0F0"
                BorderBrush="#FDE2E2"
                BorderThickness="1"
                CornerRadius="4"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Border Width="14"
                        Height="14"
                        VerticalAlignment="Center"
                        Background="#F56C6C"
                        CornerRadius="7">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="8"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="×" />
                </Border>
                <TextBlock x:Name="RuleAlertTextBlock"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#F56C6C"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
