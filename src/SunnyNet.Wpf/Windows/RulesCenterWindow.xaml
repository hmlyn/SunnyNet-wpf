<Window x:Class="SunnyNet.Wpf.Windows.RulesCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="规则中心"
        Width="940"
        Height="620"
        MinWidth="760"
        MinHeight="480"
        Background="#FFFFFF"
        Foreground="{StaticResource TextPrimaryBrush}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="RulesToolbarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="56" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F4F6F9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EAF1FF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#AEB7C5" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RulesDataGridStyle" TargetType="{x:Type DataGrid}" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Vertical" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E7EBF1" />
            <Setter Property="VerticalGridLinesBrush" Value="#E7EBF1" />
            <Setter Property="RowHeight" Value="25" />
            <Setter Property="MinRowHeight" Value="25" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="BorderBrush" Value="#E2E7EF" />
            <Setter Property="BorderThickness" Value="1,1,0,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                        <Setter Property="Height" Value="31" />
                        <Setter Property="Padding" Value="12,4" />
                        <Setter Property="Background" Value="#FAFAFC" />
                        <Setter Property="Foreground" Value="#6E7785" />
                        <Setter Property="FontWeight" Value="Normal" />
                        <Setter Property="BorderBrush" Value="#E2E7EF" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
                        <Setter Property="Padding" Value="12,2" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="BorderBrush" Value="#E7EBF1" />
                        <Setter Property="BorderThickness" Value="0,0,1,0" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E6F2FD" />
                                <Setter Property="Foreground" Value="#111827" />
                                <Setter Property="BorderBrush" Value="#D7EAFB" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Setter Property="MinHeight" Value="25" />
                        <Setter Property="Background" Value="#FFFFFF" />
                        <Setter Property="BorderBrush" Value="#E7EBF1" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5FAFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E6F2FD" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RuleEnableCheckBoxStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Border x:Name="Box"
                                Width="16"
                                Height="16"
                                Background="#E9EEF5"
                                BorderBrush="#D5DFEA"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Path x:Name="CheckMark"
                                  Data="M3.6,8.2 L6.6,11.0 L12.4,4.8"
                                  Stroke="#FFFFFF"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Visibility="Collapsed" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#4AA3F0" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="#3B91D9" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#86BFF0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Box" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="RuleEnableHeaderTemplate">
            <TextBlock Text="" />
        </DataTemplate>

        <DataTemplate x:Key="RuleEnableCellTemplate">
            <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Click="RuleEnableCheckBox_Click"
                      Style="{StaticResource RuleEnableCheckBoxStyle}" />
        </DataTemplate>

        <Style x:Key="RuleEnableCellStyle" TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#E7EBF1" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E6F2FD" />
                    <Setter Property="BorderBrush" Value="#D7EAFB" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="14,10,12,8" LastChildFill="True">
            <TextBlock x:Name="RuleStatusTextBlock"
                       DockPanel.Dock="Right"
                       Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Text="0 条" />
            <StackPanel Orientation="Horizontal">
                <Button x:Name="AddRuleButton"
                        Click="AddCurrentRule_Click"
                        Content="添加"
                        Style="{StaticResource RulesToolbarButtonStyle}" />
                <Button x:Name="RemoveRuleButton"
                        Click="RemoveSelectedRule_Click"
                        Content="删除"
                        Style="{StaticResource RulesToolbarButtonStyle}" />
                <Button x:Name="EditRuleButton"
                        Click="EditSelectedRule_Click"
                        Content="编辑"
                        Style="{StaticResource RulesToolbarButtonStyle}" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <DataGrid x:Name="BlockRulesGrid"
                      ItemsSource="{Binding RequestBlockRules}"
                      MouseDoubleClick="RulesGrid_MouseDoubleClick"
                      SelectionChanged="RulesGrid_SelectionChanged"
                      Style="{StaticResource RulesDataGridStyle}"
                      Visibility="Collapsed">
                <DataGrid.Columns>
                    <DataGridTemplateColumn HeaderTemplate="{StaticResource RuleEnableHeaderTemplate}"
                                            CellTemplate="{StaticResource RuleEnableCellTemplate}"
                                            CellStyle="{StaticResource RuleEnableCellStyle}"
                                            Width="42" />
                    <DataGridTextColumn Header="别名" Binding="{Binding Name}" Width="128" />
                    <DataGridTextColumn Header="方法" Binding="{Binding Method}" Width="66" />
                    <DataGridTextColumn Header="匹配" Binding="{Binding UrlMatchType}" Width="68" />
                    <DataGridTextColumn Header="Url" Binding="{Binding UrlPattern}" Width="260" />
                    <DataGridTextColumn Header="动作" Binding="{Binding Action}" Width="92" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="140" />
                </DataGrid.Columns>
                </DataGrid>

                <DataGrid x:Name="WebSocketBlockRulesGrid"
                      ItemsSource="{Binding WebSocketBlockRules}"
                      MouseDoubleClick="RulesGrid_MouseDoubleClick"
                      SelectionChanged="RulesGrid_SelectionChanged"
                      Style="{StaticResource RulesDataGridStyle}"
                      Visibility="Collapsed">
                <DataGrid.Columns>
                    <DataGridTemplateColumn HeaderTemplate="{StaticResource RuleEnableHeaderTemplate}"
                                            CellTemplate="{StaticResource RuleEnableCellTemplate}"
                                            CellStyle="{StaticResource RuleEnableCellStyle}"
                                            Width="42" />
                    <DataGridTextColumn Header="别名" Binding="{Binding Name}" Width="140" />
                    <DataGridTextColumn Header="匹配" Binding="{Binding UrlMatchType}" Width="72" />
                    <DataGridTextColumn Header="Url" Binding="{Binding UrlPattern}" Width="360" />
                    <DataGridTextColumn Header="动作" Binding="{Binding Action}" Width="120" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="180" />
                </DataGrid.Columns>
                </DataGrid>

                <DataGrid x:Name="TcpBlockRulesGrid"
                      ItemsSource="{Binding TcpBlockRules}"
                      MouseDoubleClick="RulesGrid_MouseDoubleClick"
                      SelectionChanged="RulesGrid_SelectionChanged"
                      Style="{StaticResource RulesDataGridStyle}"
                      Visibility="Collapsed">
                <DataGrid.Columns>
                    <DataGridTemplateColumn HeaderTemplate="{StaticResource RuleEnableHeaderTemplate}"
                                            CellTemplate="{StaticResource RuleEnableCellTemplate}"
                                            CellStyle="{StaticResource RuleEnableCellStyle}"
                                            Width="42" />
                    <DataGridTextColumn Header="别名" Binding="{Binding Name}" Width="140" />
                    <DataGridTextColumn Header="协议" Binding="{Binding Method}" Width="86" />
                    <DataGridTextColumn Header="匹配" Binding="{Binding UrlMatchType}" Width="72" />
                    <DataGridTextColumn Header="地址" Binding="{Binding UrlPattern}" Width="360" />
                    <DataGridTextColumn Header="动作" Binding="{Binding Action}" Width="120" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="180" />
                </DataGrid.Columns>
                </DataGrid>

                <DataGrid x:Name="UdpBlockRulesGrid"
                      ItemsSource="{Binding UdpBlockRules}"
                      MouseDoubleClick="RulesGrid_MouseDoubleClick"
                      SelectionChanged="RulesGrid_SelectionChanged"
                      Style="{StaticResource RulesDataGridStyle}"
                      Visibility="Collapsed">
                <DataGrid.Columns>
                    <DataGridTemplateColumn HeaderTemplate="{StaticResource RuleEnableHeaderTemplate}"
                                            CellTemplate="{StaticResource RuleEnableCellTemplate}"
                                            CellStyle="{StaticResource RuleEnableCellStyle}"
                                            Width="42" />
                    <DataGridTextColumn Header="别名" Binding="{Binding Name}" Width="140" />
                    <DataGridTextColumn Header="匹配" Binding="{Binding UrlMatchType}" Width="72" />
                    <DataGridTextColumn Header="地址" Binding="{Binding UrlPattern}" Width="380" />
                    <DataGridTextColumn Header="动作" Binding="{Binding Action}" Width="120" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="180" />
                </DataGrid.Columns>
                </DataGrid>

                <DataGrid x:Name="RewriteRulesGrid"
                      ItemsSource="{Binding RequestRewriteRules}"
                      MouseDoubleClick="RulesGrid_MouseDoubleClick"
                      SelectionChanged="RulesGrid_SelectionChanged"
                      Style="{StaticResource RulesDataGridStyle}"
                      Visibility="Collapsed">
                <DataGrid.Columns>
                    <DataGridTemplateColumn HeaderTemplate="{StaticResource RuleEnableHeaderTemplate}"
                                            CellTemplate="{StaticResource RuleEnableCellTemplate}"
                                            CellStyle="{StaticResource RuleEnableCellStyle}"
                                            Width="58" />
                    <DataGridTextColumn Header="别名" Binding="{Binding Name}" Width="150" />
                    <DataGridTextColumn Header="方法" Binding="{Binding Method}" Width="82" />
                    <DataGridTextColumn Header="匹配" Binding="{Binding UrlMatchType}" Width="82" />
                    <DataGridTextColumn Header="Url" Binding="{Binding UrlPattern}" Width="300" />
                    <DataGridTextColumn Header="方向" Binding="{Binding Direction}" Width="82" />
                    <DataGridTextColumn Header="动作链" Binding="{Binding Summary}" Width="260" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="180" />
                    <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="100" />
                </DataGrid.Columns>
                </DataGrid>

                <DataGrid x:Name="MappingRulesGrid"
                      ItemsSource="{Binding RequestMappingRules}"
                      MouseDoubleClick="RulesGrid_MouseDoubleClick"
                      SelectionChanged="RulesGrid_SelectionChanged"
                      Style="{StaticResource RulesDataGridStyle}"
                      Visibility="Collapsed">
                <DataGrid.Columns>
                    <DataGridTemplateColumn HeaderTemplate="{StaticResource RuleEnableHeaderTemplate}"
                                            CellTemplate="{StaticResource RuleEnableCellTemplate}"
                                            CellStyle="{StaticResource RuleEnableCellStyle}"
                                            Width="58" />
                    <DataGridTextColumn Header="别名" Binding="{Binding Name}" Width="150" />
                    <DataGridTextColumn Header="方法" Binding="{Binding Method}" Width="82" />
                    <DataGridTextColumn Header="匹配" Binding="{Binding UrlMatchType}" Width="82" />
                    <DataGridTextColumn Header="Url" Binding="{Binding UrlPattern}" Width="340" />
                    <DataGridTextColumn Header="映射类型" Binding="{Binding MappingType}" Width="116" />
                    <DataGridTextColumn Header="内容格式" Binding="{Binding DisplayValueType}" Width="116" />
                    <DataGridTextColumn Header="目标/内容" Binding="{Binding TargetContent}" Width="430" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="180" />
                    <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="100" />
                </DataGrid.Columns>
                </DataGrid>

                <DataGrid x:Name="DecodeRulesGrid"
                      ItemsSource="{Binding RequestDecodeRules}"
                      MouseDoubleClick="RulesGrid_MouseDoubleClick"
                      SelectionChanged="RulesGrid_SelectionChanged"
                      Style="{StaticResource RulesDataGridStyle}"
                      Visibility="Collapsed">
                <DataGrid.Columns>
                    <DataGridTemplateColumn HeaderTemplate="{StaticResource RuleEnableHeaderTemplate}"
                                            CellTemplate="{StaticResource RuleEnableCellTemplate}"
                                            CellStyle="{StaticResource RuleEnableCellStyle}"
                                            Width="58" />
                    <DataGridTextColumn Header="别名" Binding="{Binding Name}" Width="150" />
                    <DataGridTextColumn Header="方法" Binding="{Binding Method}" Width="82" />
                    <DataGridTextColumn Header="匹配" Binding="{Binding UrlMatchType}" Width="82" />
                    <DataGridTextColumn Header="Url" Binding="{Binding UrlPattern}" Width="340" />
                    <DataGridTextColumn Header="方向" Binding="{Binding Direction}" Width="82" />
                    <DataGridTextColumn Header="解码器" Binding="{Binding DecoderType}" Width="130" />
                    <DataGridTextColumn Header="参数/脚本" Binding="{Binding ScriptCode}" Width="420" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="180" />
                    <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="100" />
                </DataGrid.Columns>
                </DataGrid>

                <Border x:Name="PlaceholderListPanel"
                    Background="#FFFFFF"
                    Visibility="Collapsed">
                <TextBlock x:Name="PlaceholderTextBlock"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="该规则类型将在下一步接入。" />
                </Border>
            </Grid>
        </Grid>

        <Border x:Name="RuleAlertBorder"
                Grid.RowSpan="2"
                Panel.ZIndex="10"
                Width="320"
                Margin="0,12,0,0"
                Padding="14,10"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Background="#FEF0F0"
                BorderBrush="#FDE2E2"
                BorderThickness="1"
                CornerRadius="4"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Border Width="14"
                        Height="14"
                        VerticalAlignment="Center"
                        Background="#F56C6C"
                        CornerRadius="7">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="8"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="×" />
                </Border>
                <TextBlock x:Name="RuleAlertTextBlock"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#F56C6C"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
