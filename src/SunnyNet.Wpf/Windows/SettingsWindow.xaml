<Window x:Class="SunnyNet.Wpf.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="程序设置"
        Width="1080"
        Height="680"
        MinWidth="900"
        MinHeight="560"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}">
            <Grid Margin="22,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource DialogTitleTextStyle}" Text="程序设置" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource DialogSubtitleTextStyle}"
                               Text="配置 SunnyNet 监听、证书、代理规则和脚本能力。所有控件均为原生 WPF 重绘的浅色风格。" />
                </StackPanel>
                <Border Grid.Column="1"
                        Style="{StaticResource BadgeBorderStyle}">
                    <TextBlock Text="Windows Only" />
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="0,16,0,0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Expander x:Name="BasicExpander" IsExpanded="True" Header="常规设置">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,6,14,6" Style="{StaticResource FormLabelTextStyle}" Text="监听端口" />
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4" Text="{Binding Settings.Port}" />
                        <CheckBox Grid.Row="1" Grid.Column="1" Margin="0,8,0,4" Content="禁止 TCP" IsChecked="{Binding Settings.DisableTcp}" />
                        <CheckBox Grid.Row="2" Grid.Column="1" Margin="0,8,0,4" Content="禁止 UDP" IsChecked="{Binding Settings.DisableUdp}" />
                        <CheckBox Grid.Row="3" Grid.Column="1" Margin="0,8,0,4" Content="禁止浏览器缓存" IsChecked="{Binding Settings.DisableCache}" />
                        <CheckBox Grid.Row="4" Grid.Column="1" Margin="0,8,0,4" Content="开启身份验证模式" IsChecked="{Binding Settings.Authentication}" />
                        <Button Grid.Row="0" Grid.RowSpan="5" Grid.Column="2" Margin="18,0,0,0" VerticalAlignment="Center" Style="{StaticResource PrimaryButtonStyle}" Click="ApplyBasic_Click" Content="应用设置" />
                    </Grid>
                </Expander>

                <Expander x:Name="SslExpander" Header="SSL 证书">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,6,14,6" Style="{StaticResource FormLabelTextStyle}" Text="证书模式" />
                        <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,4" SelectedValue="{Binding Settings.CertMode}" SelectedValuePath="Content">
                            <ComboBoxItem Content="默认证书" />
                            <ComboBoxItem Content="自定义证书" />
                        </ComboBox>
                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,14,6" Style="{StaticResource FormLabelTextStyle}" Text="CA 文件" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4" Text="{Binding Settings.CaFilePath}" />
                        <Button Grid.Row="1" Grid.Column="2" Margin="10,4,0,4" Click="BrowseCa_Click" Content="浏览" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,14,6" Style="{StaticResource FormLabelTextStyle}" Text="KEY 文件" />
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,4" Text="{Binding Settings.KeyFilePath}" />
                        <Button Grid.Row="2" Grid.Column="2" Margin="10,4,0,4" Click="BrowseKey_Click" Content="浏览" />
                        <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="3" Margin="18,0,0,0" VerticalAlignment="Center">
                            <Button Margin="0,0,0,8" Click="InstallDefaultCert_Click" Content="安装默认证书" />
                            <Button Margin="0,0,0,8" Click="ExportDefaultCert_Click" Content="导出默认证书" />
                            <Button Style="{StaticResource PrimaryButtonStyle}" Click="ApplyCert_Click" Content="应用证书" />
                        </StackPanel>
                    </Grid>
                </Expander>

                <Expander x:Name="MustTcpExpander" Header="强制走 TCP">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <CheckBox Content="启用强制 TCP" IsChecked="{Binding Settings.MustTcpOpen}" />
                        <TextBox Grid.Row="1"
                                 Height="130"
                                 Margin="0,10,0,0"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding Settings.MustTcpRules}" />
                        <Button Grid.Row="2" Width="128" Margin="0,12,0,0" HorizontalAlignment="Left" Style="{StaticResource PrimaryButtonStyle}" Click="ApplyMustTcp_Click" Content="应用规则" />
                    </Grid>
                </Expander>

                <Expander x:Name="ProxyExpander" Header="上游网关">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource FormLabelTextStyle}" Text="代理地址" />
                        <TextBox Grid.Row="1" Margin="0,6,0,12" Text="{Binding Settings.GlobalProxy}" />
                        <TextBlock Grid.Row="2" Style="{StaticResource FormLabelTextStyle}" Text="代理规则" />
                        <TextBox Grid.Row="3" Height="110" Margin="0,6,0,0" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="{Binding Settings.GlobalProxyRules}" />
                        <StackPanel Grid.Row="4" Margin="0,12,0,0" Orientation="Horizontal">
                            <Button Width="128" Margin="0,0,10,0" Style="{StaticResource PrimaryButtonStyle}" Click="EnableProxy_Click" Content="启用代理" />
                            <Button Width="128" Click="DisableProxy_Click" Content="关闭代理" />
                        </StackPanel>
                    </Grid>
                </Expander>

                <Expander x:Name="HostsExpander" Header="HOSTS 设置">
                    <TextBox Height="130" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="{Binding Settings.HostsRules}" />
                </Expander>

                <Expander x:Name="ReplaceExpander" Header="替换规则">
                    <TextBox Height="130" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="{Binding Settings.ReplaceRules}" />
                </Expander>

                <Expander x:Name="ScriptExpander" Header="脚本编辑">
                    <TextBox Height="190"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas, Microsoft YaHei UI"
                             TextWrapping="NoWrap"
                             Text="{Binding Settings.ScriptCode}" />
                </Expander>

                <Expander x:Name="ProcessExpander" Header="进程拦截">
                    <TextBlock Style="{StaticResource DialogSubtitleTextStyle}" Text="Windows 版保留此界面入口，后续可继续接入进程驱动管理。" />
                </Expander>

                <Expander x:Name="RequestCertExpander" Header="请求证书">
                    <TextBlock Style="{StaticResource DialogSubtitleTextStyle}" Text="请求证书管理界面已预留，当前版本先保留入口与核心桥接。" />
                </Expander>

                <Expander x:Name="ColorExpander" Header="列表配色">
                    <TextBlock Style="{StaticResource DialogSubtitleTextStyle}" Text="列表配色配置已从 Go 配置读取，后续可继续补全颜色编辑器。" />
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
