<Window x:Class="SunnyNet.Wpf.Windows.TextCompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="文本工具"
        Width="1120"
        Height="700"
        MinWidth="900"
        MinHeight="560"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}">
            <DockPanel Margin="18,14" LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        MinWidth="88"
                        Padding="12,5"
                        Click="ClearAll_Click"
                        Content="清空" />
                <StackPanel>
                    <TextBlock Style="{StaticResource DialogTitleTextStyle}" Text="文本工具" />
                    <TextBlock x:Name="ToolSummaryTextBlock"
                               Margin="0,6,0,0"
                               Style="{StaticResource DialogSubtitleTextStyle}"
                               Text="支持编码解码、压缩解压和文本处理。" />
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="0,16,0,0">
            <TabItem Header="编码解码">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Margin="14,10" Orientation="Horizontal">
                            <ComboBox x:Name="CodecComboBox" Width="150" SelectedIndex="0">
                                <ComboBoxItem Content="Base64" />
                                <ComboBoxItem Content="URL" />
                                <ComboBoxItem Content="UCS2" />
                            </ComboBox>
                            <CheckBox x:Name="CodecHexCheckBox" Margin="14,0,0,0" VerticalAlignment="Center" Content="输入/输出HEX" />
                            <Button Margin="14,0,0,0" MinWidth="88" Padding="12,5" Click="Encode_Click" Content="编码" />
                            <Button Margin="8,0,0,0" MinWidth="88" Padding="12,5" Click="Decode_Click" Content="解码" />
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <TextBox x:Name="CodecInputTextBox" Margin="12" AcceptsReturn="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" FontFamily="Consolas, Microsoft YaHei UI" TextWrapping="NoWrap" />
                        </Border>
                        <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" />
                        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                            <TextBox x:Name="CodecOutputTextBox" Margin="12" AcceptsReturn="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" FontFamily="Consolas, Microsoft YaHei UI" TextWrapping="NoWrap" />
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="压缩解压">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Margin="14,10" Orientation="Horizontal">
                            <ComboBox x:Name="CompressComboBox" Width="150" SelectedIndex="0">
                                <ComboBoxItem Content="GZIP" />
                                <ComboBoxItem Content="ZLIB" />
                                <ComboBoxItem Content="Brotli" />
                            </ComboBox>
                            <CheckBox x:Name="CompressHexCheckBox" Margin="14,0,0,0" VerticalAlignment="Center" Content="输入/输出HEX" IsChecked="True" />
                            <Button Margin="14,0,0,0" MinWidth="88" Padding="12,5" Click="Compress_Click" Content="压缩" />
                            <Button Margin="8,0,0,0" MinWidth="88" Padding="12,5" Click="Decompress_Click" Content="解压" />
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <TextBox x:Name="CompressInputTextBox" Margin="12" AcceptsReturn="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" FontFamily="Consolas, Microsoft YaHei UI" TextWrapping="NoWrap" />
                        </Border>
                        <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" />
                        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                            <TextBox x:Name="CompressOutputTextBox" Margin="12" AcceptsReturn="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" FontFamily="Consolas, Microsoft YaHei UI" TextWrapping="NoWrap" />
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="文本处理">
                <TabControl Margin="0,12,0,0">
                    <TabItem Header="差异对比">
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="48" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0">
                                        <TextBlock x:Name="LeftTitleTextBlock" Margin="16,0" VerticalAlignment="Center" Style="{StaticResource SectionTitleTextStyle}" Text="左侧文本" />
                                    </Border>
                                    <RichTextBox x:Name="LeftEditor" Grid.Row="1" Margin="12" AcceptsTab="True" FontFamily="Consolas, Microsoft YaHei UI" FontSize="12" HorizontalScrollBarVisibility="Auto" TextChanged="Editor_TextChanged" VerticalScrollBarVisibility="Auto" />
                                </Grid>
                            </Border>
                            <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" />
                            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="48" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0">
                                        <TextBlock x:Name="RightTitleTextBlock" Margin="16,0" VerticalAlignment="Center" Style="{StaticResource SectionTitleTextStyle}" Text="右侧文本" />
                                    </Border>
                                    <RichTextBox x:Name="RightEditor" Grid.Row="1" Margin="12" AcceptsTab="True" FontFamily="Consolas, Microsoft YaHei UI" FontSize="12" HorizontalScrollBarVisibility="Auto" TextChanged="Editor_TextChanged" VerticalScrollBarVisibility="Auto" />
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="文本去重">
                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel Margin="14,10" Orientation="Horizontal">
                                    <Button MinWidth="100" Padding="12,5" Click="RemoveDuplicateLines_Click" Content="开始去重" />
                                </StackPanel>
                            </Border>
                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="36" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Margin="12,0" VerticalAlignment="Center" Style="{StaticResource SectionTitleTextStyle}" Text="原始数据" />
                                        <TextBox x:Name="DistinctLeftTextBox" Grid.Row="1" Margin="12" AcceptsReturn="True" Background="White" Foreground="{StaticResource TextPrimaryBrush}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" FontFamily="Consolas, Microsoft YaHei UI" TextWrapping="NoWrap" />
                                    </Grid>
                                </Border>
                                <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" />
                                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="36" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Margin="12,0" VerticalAlignment="Center" Style="{StaticResource SectionTitleTextStyle}" Text="去重结果" />
                                        <TextBox x:Name="DistinctOutputTextBox" Grid.Row="1" Margin="12" AcceptsReturn="True" Background="White" Foreground="{StaticResource TextPrimaryBrush}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" FontFamily="Consolas, Microsoft YaHei UI" TextWrapping="NoWrap" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="时间戳转换">
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="1.3*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel Margin="16">
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="时间转时间戳" />
                                    <TextBox x:Name="DateTimeInputTextBox" Margin="0,12,0,0" Height="40" Padding="10,6" Background="White" Foreground="#1F2D3D" CaretBrush="#1E50C8" VerticalContentAlignment="Center" Text="2026-04-25 12:00:00" />
                                    <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                        <Button MinWidth="100" Padding="12,5" Click="UseCurrentTime_Click" Content="当前时间" />
                                        <Button Margin="8,0,0,0" MinWidth="120" Padding="12,5" Click="DateTimeToTimestamp_Click" Content="转换为时间戳" />
                                    </StackPanel>
                                    <TextBlock Margin="0,18,0,0" Style="{StaticResource SectionTitleTextStyle}" Text="时间戳转时间" />
                                    <TextBox x:Name="TimestampInputTextBox" Margin="0,12,0,0" Height="40" Padding="10,6" Background="White" Foreground="#1F2D3D" CaretBrush="#1E50C8" VerticalContentAlignment="Center" />
                                    <Button Margin="0,12,0,0" MinWidth="120" HorizontalAlignment="Left" Padding="12,5" Click="TimestampToDateTime_Click" Content="转换为时间" />
                                </StackPanel>
                            </Border>
                            <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" />
                            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                <TextBox x:Name="TimestampOutputTextBox" Margin="12" AcceptsReturn="True" IsReadOnly="True" Background="White" Foreground="{StaticResource TextPrimaryBrush}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" FontFamily="Consolas, Microsoft YaHei UI" TextWrapping="NoWrap" />
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="大小写转换">
                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel Margin="14,10" Orientation="Horizontal">
                                    <Button MinWidth="96" Padding="12,5" Click="UpperCase_Click" Content="转大写" />
                                    <Button Margin="8,0,0,0" MinWidth="96" Padding="12,5" Click="LowerCase_Click" Content="转小写" />
                                    <Button Margin="8,0,0,0" MinWidth="110" Padding="12,5" Click="TitleCase_Click" Content="首字母大写" />
                                </StackPanel>
                            </Border>
                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <TextBox x:Name="CaseInputTextBox" Margin="12" AcceptsReturn="True" Background="White" Foreground="{StaticResource TextPrimaryBrush}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" FontFamily="Consolas, Microsoft YaHei UI" TextWrapping="NoWrap" />
                                </Border>
                                <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch" />
                                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                    <TextBox x:Name="CaseOutputTextBox" Margin="12" AcceptsReturn="True" Background="White" Foreground="{StaticResource TextPrimaryBrush}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" FontFamily="Consolas, Microsoft YaHei UI" TextWrapping="NoWrap" />
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
